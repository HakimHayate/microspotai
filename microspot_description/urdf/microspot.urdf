<?xml version="1.0"?>

<robot name="my_robot">

    <material name="green">
        <color rgba="0 0.6 0 1" />
    </material>

    <!-- DUMMY LINK -->
    <link name="world_link">
    </link>

    <link name="base_link">
        <visual>
            <geometry>
               <box size="0.15 0.12 0.04" />
            </geometry>
            
            <material name="green"/>
        </visual>

        <collision>
            <geometry>
               <box size="0.15 0.12 0.04" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>

        <!-- Inertia calculated based on perfect rectangle -->
        <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        
        <mass value="0.5"/>
        
        <inertia ixx="0.0003333" ixy="0.0"       ixz="0.0" 
                                iyy="0.0004979" iyz="0.0" 
                                                izz="0.0007688"/>
    </inertial>
    </link>

    <joint name="base_joint" type="fixed">
        <parent link="world_link" />
        <child link="base_link" />
        <origin xyz="0 0 0.1" rpy="0 0 0" />
    </joint>

    <!-- FRONT RIGHT LEG -->

    <link name="front_right_hip">
        <visual>
            <geometry>
                <box size="0.04 0.06 0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="gray" />
        </visual>

        <collision>
            <geometry>
                <box size="0.04 0.06 0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>

        <inertial>
            <origin xyz="-0.00398 0.00085 -0.00004" rpy="0 0 0"/>
            <mass value="0.02721"/>
            <inertia ixx="0.00001383" ixy="0.0" ixz="0.0" 
                                      iyy="0.00000930" iyz="0.0" 
                                                      izz="0.00001179"/>
        </inertial>
    </link>

    <link name="front_right_thigh">
        <visual>
            <geometry>
               <box size="0.13 0.03 0.02" />
            </geometry>
            <origin xyz="0.05 0 0" rpy="0 0 0" />
            <material name="green"/>
        </visual>

        <collision>
            <geometry>
                <box size="0.13 0.03 0.02" />
            </geometry>
            <origin xyz="0.05 0 0" rpy="0 0 0" />
        </collision>

        <inertial>
            <origin xyz="0.05 0.0 0.0" rpy="0 0 0"/>
            <mass value="0.0578"/>
            <inertia ixx="0.00000626" ixy="0.0" ixz="0.0" 
                                      iyy="0.0000833" iyz="0.0" 
                                                      izz="0.0000854"/>
        </inertial>
    </link>

    <joint name="front_right_hip_joint" type="revolute">
        <parent link="base_link" />
        <child link="front_right_hip" />
        <origin xyz="0.095 -0.05 0" rpy="0 0 0" />
        <axis xyz="-1 0  0"/>
        <limit lower="-1.4" upper="1.05" velocity="7.48" effort="2.55"/>
    </joint>

    <joint name="front_right_thigh_joint" type="revolute">
        <parent link="front_right_hip" />
        <child link="front_right_thigh" />
        <origin xyz="0 -0.045 0" rpy="0 1.57 0" />
        <axis xyz="0 -1  0"/>
        <limit lower="-1.57" upper="1.57" velocity="7.48" effort="2.55"/>
    </joint>

    <link name="front_right_knee">
        <visual>
            <geometry>
               <box size="0.13 0.015 0.015" />
            </geometry>
            <origin xyz="0.05 0 0" rpy="0 0 0" />
            <material name="green"/>
        </visual>

        <collision>
            <geometry>
                <box size="0.13 0.015 0.015" />
            </geometry>
            <origin xyz="0.05 0 0" rpy="0 0 0" />
        </collision>

        <inertial>
            <origin xyz="0.05 0.0 0.0" rpy="0 0 0"/>
            <mass value="0.03019"/>
            <inertia ixx="0.00000113" ixy="0.0" ixz="0.0" 
                                      iyy="0.00004308" iyz="0.0" 
                                                      izz="0.00004308"/>
        </inertial>
    </link>

    <joint name="front_right_knee_joint" type="revolute">
        <parent link="front_right_thigh" />
        <child link="front_right_knee" />
        <origin xyz="0.13 0 0" rpy="0 0 0" />
        <axis xyz="0 -1  0"/>
        <limit lower="0" upper="2.61799" velocity="7.48" effort="2.55"/>
    </joint>

    <link name="front_right_feet">
    </link>

    <joint name="front_right_feet_joint" type="fixed">
        <parent link="front_right_knee" />
        <child link="front_right_feet" />
        <origin xyz="0.13 0 0" rpy="0 -1.57 0" />
    </joint>
    <gazebo reference="front_right_feet"> <mu1>1.5</mu1> <mu2>1.5</mu2> </gazebo>
    <!-- BACK RIGHT LEG -->


    <link name="back_right_hip">
