    <ros2_control name="MicroSpotHardwareInterface" type="system">
        <hardware>
            <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </hardware>
        
        <joint name="front_right_hip_joint">
            <command_interface name="position">
                <param name="min">-1.4</param>
                <param name="max">1.05</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="front_right_thigh_joint">
            <command_interface name="position">
                <param name="min">-1.57</param>
                <param name="max">1.57</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="front_right_knee_joint">
            <command_interface name="position">
                <param name="min">0</param>
                <param name="max">2.62</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="back_right_hip_joint">
            <command_interface name="position">
                <param name="min">-1.4</param>
                <param name="max">1.05</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
