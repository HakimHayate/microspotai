    <!-- FRONT LEFT LEG -->


    <link name="front_left_hip">
        <visual>
            <geometry>
                <box size="0.04 0.06 0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="gray" />
        </visual>

        <collision>
            <geometry>
                <box size="0.04 0.06 0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>

